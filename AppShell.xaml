<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AppLanches.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:AppLanches"
    xmlns:pages="clr-namespace:Pages"
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarBackgroundColor="#FF956163"
    Shell.TabBarTitleColor="White"
    Shell.TabBarUnselectedColor="FloralWhite">

    <TabBar>
        <Tab Title="Home" Icon="home.png">
            <ShellContent ContentTemplate="{DataTemplate pages:HomePage}" />
        </Tab>
        <Tab Title="Carrinho" Icon="carrinho.png">
            <ShellContent ContentTemplate="{DataTemplate pages:CarrinhoPage}" />
        </Tab>
        <Tab Title="Favoritos" Icon="favorito.png">
            <ShellContent ContentTemplate="{DataTemplate pages:FavoritoPage}" />
        </Tab>
        <Tab Title="Perfil" Icon="perfil.png">
            <ShellContent ContentTemplate="{DataTemplate pages:PerfilPage}" />
        </Tab>
    </TabBar>

</Shell>
